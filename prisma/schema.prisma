generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FactoryPlatform {
  YOUTUBE
  TIKTOK
}

enum FactoryJobStatus {
  QUEUED
  DOWNLOADING
  RENDERING
  PUBLISHING
  DONE
  FAILED
  CANCELED
}

enum FactoryPublishStatus {
  QUEUED
  UPLOADING
  PUBLISHED
  FAILED
  SKIPPED
  CANCELED
}

enum FactoryGame {
  ROBLOX
  FORTNITE
  MINECRAFT
  BRAWL_STARS
  DOTA2
  OTHER
}

enum FactoryPublishTiming {
  NOW
  NY_14
  NY_17
  NY_20
  NY_22
  USA_SMART
}

enum FactoryCutMode {
  SEQUENTIAL
  SMART_LITE
}

model FactoryAsset {
  id           String   @id @default(cuid())
  title        String
  filePath     String
  storageKey   String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  templates    FactoryTemplate[]

  @@index([createdAt])
  @@index([storageKey])
}

model FactoryThumbnail {
  id           String      @id @default(cuid())
  title        String
  game         FactoryGame @default(OTHER)
  filePath     String
  storageKey   String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  isActive     Boolean     @default(true)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([game])
  @@index([isActive])
  @@index([createdAt])
  @@index([storageKey])
}

model FactoryTemplate {
  id          String   @id @default(cuid())
  name        String
  isDefault   Boolean  @default(false)

  assetId     String?
  asset       FactoryAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  lanaX       Int      @default(78)
  lanaY       Int      @default(68)
  lanaWidth   Int      @default(300)
  lanaHeight  Int      @default(533)
  mirrorLana  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs         FactoryJob[]
  jobTargets   FactoryJobTarget[]

  @@index([isDefault])
  @@index([createdAt])
  @@index([assetId])
}

model FactoryAccount {
  id           String          @id @default(cuid())
  platform     FactoryPlatform
  name         String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  targets      FactoryJobTarget[]
  publishes    FactoryPublish[]

  @@unique([platform, name])
  @@index([platform])
}

model FactoryJob {
  id                 String            @id @default(cuid())

  sourceUrl          String?
  sourceFilePath     String?
  sourceStorageKey   String?
  sourceOriginalName String?
  sourceSizeBytes    Int?

  clipSeconds        Int               @default(45)
  clipStartIndex     Int               @default(0)
  titlePrefix        String            @default("crazy gaming moments")
  game               FactoryGame       @default(OTHER)

  templateId         String?
  template           FactoryTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  platforms          FactoryPlatform[]

  status             FactoryJobStatus  @default(QUEUED)
  error              String?
  totalClips         Int               @default(0)

  progress           Int               @default(0)
  progressLabel      String?
  publishTiming      FactoryPublishTiming @default(NOW)
  scheduledAt        DateTime?

  cutMode            FactoryCutMode    @default(SEQUENTIAL)
  smartStepSeconds   Int               @default(10)
  smartCandidates    Int               @default(80)
  smartMinGapSeconds Int               @default(30)

  cancelRequested    Boolean           @default(false)
  canceledAt         DateTime?

  targets            FactoryJobTarget[]
  clips              FactoryClip[]
  candidates         FactoryClipCandidate[]

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([cancelRequested])
  @@index([sourceStorageKey])
  @@index([game])
  @@index([clipStartIndex])
  @@index([templateId])
  @@index([publishTiming])
  @@index([scheduledAt])
  @@index([cutMode])
}

model FactoryJobTarget {
  id          String          @id @default(cuid())

  jobId       String
  job         FactoryJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  accountId   String
  account     FactoryAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  platform    FactoryPlatform

  templateId  String?
  template    FactoryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  titlePrefix String?
  maxClips    Int             @default(10)

  publishes   FactoryPublish[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([jobId, accountId])
  @@index([jobId])
  @@index([accountId])
  @@index([platform])
  @@index([templateId])
}

model FactoryClip {
  id         String      @id @default(cuid())
  jobId      String
  job        FactoryJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  index      Int
  startSec   Int
  endSec     Int
  title      String
  filePath   String?
  storageKey String?

  publishes  FactoryPublish[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([jobId])
  @@index([createdAt])
  @@index([storageKey])
}

model FactoryClipCandidate {
  id              String     @id @default(cuid())

  jobId           String
  job             FactoryJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  startSec        Int
  endSec          Int
  durationSec     Int

  motionScore     Int        @default(0)
  audioScore      Int        @default(0)
  firstFrameScore Int        @default(0)
  sceneScore      Int        @default(0)
  finalScore      Int        @default(0)

  selected        Boolean    @default(false)
  reason          String?

  createdAt       DateTime   @default(now())

  @@index([jobId])
  @@index([finalScore])
  @@index([selected])
}

model FactoryPublish {
  id               String               @id @default(cuid())

  clipId           String
  clip             FactoryClip          @relation(fields: [clipId], references: [id], onDelete: Cascade)

  targetId         String?
  target           FactoryJobTarget?    @relation(fields: [targetId], references: [id], onDelete: SetNull)

  accountId        String?
  account          FactoryAccount?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  platform         FactoryPlatform
  status           FactoryPublishStatus @default(QUEUED)

  platformPostId   String?
  platformUrl      String?

  renderFilePath   String?
  renderStorageKey String?

  error            String?

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([clipId])
  @@index([targetId])
  @@index([accountId])
  @@index([platform])
  @@index([status])
}
