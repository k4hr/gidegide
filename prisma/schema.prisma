generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FactoryAssetType {
  HOOK
  LANA
}

enum FactoryPlatform {
  YOUTUBE
  TIKTOK
}

enum FactoryJobStatus {
  QUEUED
  DOWNLOADING
  RENDERING
  PUBLISHING
  DONE
  FAILED
}

enum FactoryPublishStatus {
  QUEUED
  UPLOADING
  PUBLISHED
  FAILED
  SKIPPED
}

model FactoryAsset {
  id           String           @id @default(cuid())
  type         FactoryAssetType
  title        String
  filePath     String
  originalName String?
  mimeType     String?
  sizeBytes    Int?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([type])
  @@index([createdAt])
}

model FactoryAccount {
  id           String          @id @default(cuid())
  platform     FactoryPlatform
  name         String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([platform, name])
  @@index([platform])
}

model FactoryJob {
  id          String            @id @default(cuid())
  sourceUrl   String
  clipSeconds Int               @default(45)
  titlePrefix String            @default("Lana watches games")
  platforms   FactoryPlatform[]
  status      FactoryJobStatus  @default(QUEUED)
  error       String?
  totalClips  Int               @default(0)

  clips       FactoryClip[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
}

model FactoryClip {
  id        String   @id @default(cuid())
  jobId     String
  job       FactoryJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  index     Int
  startSec  Int
  endSec    Int
  title     String
  filePath  String?

  publishes FactoryPublish[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([createdAt])
}

model FactoryPublish {
  id             String               @id @default(cuid())
  clipId         String
  clip           FactoryClip           @relation(fields: [clipId], references: [id], onDelete: Cascade)

  platform       FactoryPlatform
  status         FactoryPublishStatus  @default(QUEUED)
  platformPostId String?
  platformUrl    String?
  error          String?

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([clipId])
  @@index([platform])
  @@index([status])
}
