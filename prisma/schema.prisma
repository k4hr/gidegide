generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FactoryPlatform {
  YOUTUBE
  TIKTOK
}

enum FactoryJobStatus {
  QUEUED
  DOWNLOADING
  RENDERING
  PUBLISHING
  DONE
  FAILED
  CANCELED
}

enum FactoryPublishStatus {
  QUEUED
  UPLOADING
  PUBLISHED
  FAILED
  SKIPPED
  CANCELED
}

model FactoryAsset {
  id           String   @id @default(cuid())
  title        String
  filePath     String
  storageKey   String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([storageKey])
}

model FactoryAccount {
  id           String          @id @default(cuid())
  platform     FactoryPlatform
  name         String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([platform, name])
  @@index([platform])
}

model FactoryJob {
  id                 String            @id @default(cuid())

  sourceUrl          String?
  sourceFilePath     String?
  sourceStorageKey   String?
  sourceOriginalName String?
  sourceSizeBytes    Int?

  clipSeconds        Int               @default(45)
  titlePrefix        String            @default("Lana watches games")
  platforms          FactoryPlatform[]

  status             FactoryJobStatus  @default(QUEUED)
  error              String?
  totalClips         Int               @default(0)

  progress           Int               @default(0)
  progressLabel      String?
  cancelRequested    Boolean           @default(false)
  canceledAt         DateTime?

  clips              FactoryClip[]

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([cancelRequested])
  @@index([sourceStorageKey])
}

model FactoryClip {
  id         String      @id @default(cuid())
  jobId      String
  job        FactoryJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  index      Int
  startSec   Int
  endSec     Int
  title      String
  filePath   String?
  storageKey String?

  publishes  FactoryPublish[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([jobId])
  @@index([createdAt])
  @@index([storageKey])
}

model FactoryPublish {
  id             String               @id @default(cuid())
  clipId         String
  clip           FactoryClip          @relation(fields: [clipId], references: [id], onDelete: Cascade)

  platform       FactoryPlatform
  status         FactoryPublishStatus @default(QUEUED)
  platformPostId String?
  platformUrl    String?
  error          String?

  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([clipId])
  @@index([platform])
  @@index([status])
}
