generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LessonPlatform {
  INSTAGRAM
  TIKTOK
  YOUTUBE_SHORTS
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum FactoryPlatform {
  YOUTUBE
  TIKTOK
}

enum FactoryJobStatus {
  QUEUED
  DOWNLOADING
  RENDERING
  PUBLISHING
  DONE
  FAILED
  CANCELED
}

enum FactoryPublishStatus {
  QUEUED
  UPLOADING
  PUBLISHED
  FAILED
  SKIPPED
  CANCELED
}

enum FactoryGame {
  ROBLOX
  FORTNITE
  MINECRAFT
  BRAWL_STARS
  DOTA2
  OTHER
}

enum FactoryPublishTiming {
  NOW
  NY_14
  NY_17
  NY_20
  NY_22
  USA_SMART
}

enum FactoryCutMode {
  SEQUENTIAL
  SMART_LITE
  SMART_HOOK_AI
  ROBLOX_STORY_AI
  MOVIE_SMART
}

enum FactoryTemplateKind {
  SHORTS_9_16
  LONG_16_9
}

enum FactoryFacecamPosition {
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
}

enum FactoryRenderFormat {
  SHORTS_9_16
  LONG_16_9
}

enum FactoryDonorKind {
  SUPER_UPLOAD
  STORY_SHORTS
  MOVIE_MOMENTS
}

model Lesson {
  id          String         @id @default(cuid())
  slug        String         @unique
  platform    LessonPlatform
  title       String
  subtitle    String
  description String
  priceRub    Int
  oldPriceRub Int?
  content     String
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  orders      Order[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([slug])
  @@index([platform])
  @@index([isActive])
}

model Order {
  id          String      @id @default(cuid())
  email       String
  status      OrderStatus @default(PENDING)
  lessonId    String
  lesson      Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  accessToken String      @unique
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([email])
  @@index([status])
  @@index([lessonId])
  @@index([accessToken])
}

model FactoryAsset {
  id           String            @id @default(cuid())
  title        String
  filePath     String
  storageKey   String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  templates    FactoryTemplate[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([createdAt])
  @@index([storageKey])
}

model FactoryAccount {
  id                String               @id @default(cuid())
  platform          FactoryPlatform
  name              String
  accessToken        String
  refreshToken       String?
  expiresAt          DateTime?
  platformChannelId  String?
  targets           FactoryJobTarget[]
  publishes         FactoryPublish[]
  metrics           FactoryVideoMetric[]
  analyses          FactoryVideoAnalysis[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([platform, name])
  @@index([platform])
  @@index([platformChannelId])
}

model FactoryTemplate {
  id                         String                   @id @default(cuid())
  name                       String
  isDefault                  Boolean                  @default(false)
  lanaX                      Int                      @default(78)
  lanaY                      Int                      @default(68)
  lanaWidth                  Int                      @default(300)
  lanaHeight                 Int                      @default(533)
  mirrorLana                 Boolean                  @default(false)
  assetId                    String?
  asset                      FactoryAsset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  kind                       FactoryTemplateKind      @default(SHORTS_9_16)
  facecamPosition            FactoryFacecamPosition   @default(TOP_LEFT)
  facecamWidthPercent        Int                      @default(24)
  facecamMarginPercent       Int                      @default(3)
  facecamBorderRadius        Int                      @default(18)
  facecamCropZoomPercent     Int                      @default(135)
  facecamCropFocusXPercent   Int                      @default(50)
  facecamCropFocusYPercent   Int                      @default(50)
  jobs                       FactoryJob[]
  targets                    FactoryJobTarget[]
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  @@index([isDefault])
  @@index([createdAt])
  @@index([assetId])
  @@index([kind])
}

model FactoryJob {
  id                              String                      @id @default(cuid())
  sourceUrl                       String?
  sourceFilePath                  String?
  sourceStorageKey                String?
  sourceOriginalName              String?
  sourceSizeBytes                 Int?
  clipSeconds                     Int                         @default(45)
  clipStartIndex                  Int                         @default(0)
  titlePrefix                     String                      @default("Lana watches games")
  game                            FactoryGame                 @default(OTHER)
  platforms                       FactoryPlatform[]
  status                          FactoryJobStatus            @default(QUEUED)
  error                           String?
  totalClips                      Int                         @default(0)
  progress                        Int                         @default(0)
  progressLabel                   String?
  cancelRequested                 Boolean                     @default(false)
  canceledAt                      DateTime?
  templateId                      String?
  template                        FactoryTemplate?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  publishTiming                   FactoryPublishTiming        @default(NOW)
  scheduledAt                     DateTime?
  cutMode                         FactoryCutMode              @default(SEQUENTIAL)
  smartStepSeconds                Int                         @default(10)
  smartCandidates                 Int                         @default(80)
  smartMinGapSeconds              Int                         @default(30)
  hookPreviewSeconds              Int                         @default(8)
  renderFormat                    FactoryRenderFormat         @default(SHORTS_9_16)
  longVideoTitle                  String?
  longVideoDescription            String?
  longVideoThumbnailPath          String?
  longVideoThumbnailStorageKey    String?
  longVideoFacecamPosition        FactoryFacecamPosition?
  longVideoFacecamWidthPercent    Int?
  longVideoFacecamMarginPercent   Int?
  storyStyle                      String                      @default("AUTO")
  storyMinSeconds                 Int                         @default(10)
  storyMaxSeconds                 Int                         @default(35)
  storyMusicMood                  String                      @default("AUTO")
  storySourceVolume               Int                         @default(10)
  storyUseEmojis                  Boolean                     @default(true)
  viralFormulaId                  String?
  viralFormulaSnapshot            Json?
  viralBrainSnapshot              Json?
  recommendation                  String?
  superUploadPackageId            String?
  superUploadPackage              FactorySuperUploadPackage?  @relation(fields: [superUploadPackageId], references: [id], onDelete: SetNull)
  clips                           FactoryClip[]
  targets                         FactoryJobTarget[]
  clipCandidates                  FactoryClipCandidate[]
  vkCandidates                    FactoryVkVideoCandidate[]
  telegramJobs                   FactoryTelegramJob[]
  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([cancelRequested])
  @@index([sourceStorageKey])
  @@index([game])
  @@index([templateId])
  @@index([publishTiming])
  @@index([scheduledAt])
  @@index([clipStartIndex])
  @@index([cutMode])
  @@index([hookPreviewSeconds])
  @@index([renderFormat])
  @@index([storyStyle])
  @@index([superUploadPackageId])
}

model FactoryTelegramChat {
  id        String   @id @default(cuid())
  chatId    String   @unique
  username  String?
  firstName String?
  isAllowed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs FactoryTelegramJob[]

  @@index([chatId])
  @@index([isAllowed])
}

model FactoryTelegramJob {
  id                String               @id @default(cuid())
  chatId            String
  chat              FactoryTelegramChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  factoryJobId      String?
  factoryJob        FactoryJob?           @relation(fields: [factoryJobId], references: [id], onDelete: SetNull)
  telegramMessageId String?
  sourceUrl         String
  status            String               @default("CREATED")
  lastStatusText    String?
  settings          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([chatId])
  @@index([factoryJobId])
  @@index([status])
}

model FactoryJobTarget {
  id          String            @id @default(cuid())
  jobId       String
  job         FactoryJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  accountId   String
  account     FactoryAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform    FactoryPlatform
  templateId  String?
  template    FactoryTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  titlePrefix String?
  maxClips    Int               @default(10)
  publishes   FactoryPublish[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, accountId])
  @@index([jobId])
  @@index([accountId])
  @@index([platform])
  @@index([templateId])
}

model FactoryClip {
  id             String                  @id @default(cuid())
  jobId          String
  job            FactoryJob              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  index          Int
  startSec       Int
  endSec         Int
  title          String
  filePath       String?
  storageKey     String?
  publishes      FactoryPublish[]
  metrics        FactoryVideoMetric[]
  analyses       FactoryVideoAnalysis[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([jobId])
  @@index([createdAt])
  @@index([storageKey])
}

model FactoryPublish {
  id              String                   @id @default(cuid())
  clipId          String
  clip            FactoryClip              @relation(fields: [clipId], references: [id], onDelete: Cascade)
  targetId        String?
  target          FactoryJobTarget?        @relation(fields: [targetId], references: [id], onDelete: SetNull)
  accountId       String?
  account         FactoryAccount?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  platform        FactoryPlatform
  status          FactoryPublishStatus     @default(QUEUED)
  platformPostId  String?
  platformUrl     String?
  error           String?
  renderFilePath  String?
  renderStorageKey String?
  title           String?
  description     String?
  publishedAt     DateTime?
  metrics         FactoryVideoMetric[]
  analysis        FactoryVideoAnalysis?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([clipId])
  @@index([platform])
  @@index([status])
  @@index([targetId])
  @@index([accountId])
  @@index([platformPostId])
  @@index([publishedAt])
}

model FactoryThumbnail {
  id           String       @id @default(cuid())
  title        String
  game         FactoryGame  @default(OTHER)
  filePath     String
  storageKey   String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([game])
  @@index([isActive])
  @@index([createdAt])
  @@index([storageKey])
}

model FactoryClipCandidate {
  id                     String     @id @default(cuid())
  jobId                  String
  job                    FactoryJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  startSec               Int
  endSec                 Int
  durationSec            Int
  motionScore            Int        @default(0)
  audioScore             Int        @default(0)
  firstFrameScore        Int        @default(0)
  sceneScore             Int        @default(0)
  finalScore             Int        @default(0)
  selected               Boolean    @default(false)
  reason                 String?
  aiScore                Int        @default(0)
  hookMomentSec          Int?
  hookPreviewStartSec    Int?
  hookPreviewDurationSec Int?
  overlayText            String?
  aiTitle                String?
  momentType             String?
  createdAt              DateTime   @default(now())

  @@index([jobId])
  @@index([finalScore])
  @@index([selected])
}

model FactoryVideoMetric {
  id                       String          @id @default(cuid())
  publishId                String
  publish                  FactoryPublish  @relation(fields: [publishId], references: [id], onDelete: Cascade)
  clipId                   String
  clip                     FactoryClip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  accountId                String?
  account                  FactoryAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  platform                 FactoryPlatform
  platformVideoId          String
  views                    Int             @default(0)
  likes                    Int             @default(0)
  comments                 Int             @default(0)
  shares                   Int             @default(0)
  estimatedMinutesWatched  Int             @default(0)
  averageViewDuration      Float           @default(0)
  averageViewPercentage    Float           @default(0)
  subscribersGained        Int             @default(0)
  subscribersLost          Int             @default(0)
  ageMinutes               Int             @default(0)
  checkedAt                DateTime        @default(now())
  createdAt                DateTime        @default(now())

  @@index([publishId])
  @@index([clipId])
  @@index([accountId])
  @@index([platform])
  @@index([platformVideoId])
  @@index([checkedAt])
  @@index([ageMinutes])
}

model FactoryVideoAnalysis {
  id                         String          @id @default(cuid())
  publishId                  String          @unique
  publish                    FactoryPublish  @relation(fields: [publishId], references: [id], onDelete: Cascade)
  clipId                     String
  clip                       FactoryClip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  accountId                  String?
  account                    FactoryAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  platform                   FactoryPlatform
  platformVideoId            String
  viewsNow                   Int             @default(0)
  views1h                    Int             @default(0)
  views3h                    Int             @default(0)
  views6h                    Int             @default(0)
  views24h                   Int             @default(0)
  views48h                   Int             @default(0)
  likesNow                   Int             @default(0)
  commentsNow                Int             @default(0)
  sharesNow                  Int             @default(0)
  likes24h                   Int             @default(0)
  comments24h                Int             @default(0)
  shares24h                  Int             @default(0)
  subscribersGained24h       Int             @default(0)
  subscribersLost24h         Int             @default(0)
  estimatedMinutesWatched24h Int             @default(0)
  averageViewDuration24h     Float           @default(0)
  averageViewPercentage24h   Float           @default(0)
  likeRate                   Float           @default(0)
  commentRate                Float           @default(0)
  subscriberRate             Float           @default(0)
  factoryScore               Int             @default(0)
  velocityType               String          @default("UNKNOWN")
  verdict                    String          @default("WAITING")
  recommendation             String?
  lastCheckedAt              DateTime?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  @@index([clipId])
  @@index([accountId])
  @@index([platform])
  @@index([platformVideoId])
  @@index([factoryScore])
  @@index([verdict])
  @@index([lastCheckedAt])
}

model FactorySourceVideo {
  id                    String                     @id @default(cuid())
  sourceVideoId          String
  sourceUrl              String
  channelId              String?
  channelTitle           String?
  title                  String
  description            String?
  thumbnailUrl           String?
  durationSeconds        Int?
  publishedAt            DateTime?
  views                  Int                        @default(0)
  likes                  Int                        @default(0)
  comments               Int                        @default(0)
  viewsPerDay            Float                      @default(0)
  likeRate               Float                      @default(0)
  commentRate            Float                      @default(0)
  sourceScore            Int                        @default(0)
  viralChance            Int                        @default(0)
  suggestedClips         Int                        @default(5)
  suggestedHookMode      String                     @default("AUTO_BEST_MIX")
  suggestedWindow        String                     @default("ANALYTICS_BEST_WINDOW")
  isUsed                 Boolean                    @default(false)
  usedAt                 DateTime?
  notes                  String?
  donorChannelId         String?
  donorChannel           FactoryDonorChannel?       @relation(fields: [donorChannelId], references: [id], onDelete: SetNull)
  sourceKind             FactoryDonorKind           @default(SUPER_UPLOAD)
  packages               FactorySuperUploadPackage[]
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  @@unique([sourceVideoId, sourceKind])
  @@index([channelId])
  @@index([sourceScore])
  @@index([viralChance])
  @@index([isUsed])
  @@index([publishedAt])
  @@index([donorChannelId])
  @@index([sourceKind])
}

model FactorySuperUploadPackage {
  id                 String              @id @default(cuid())
  sourceVideoId       String
  sourceVideo         FactorySourceVideo  @relation(fields: [sourceVideoId], references: [id], onDelete: Cascade)
  accountId           String?
  accountName         String?
  game                FactoryGame         @default(ROBLOX)
  clipsCount          Int
  clipSeconds         Int
  intervalMin         Int                 @default(20)
  intervalMax         Int                 @default(30)
  scheduleMode        String              @default("ANALYTICS_BEST_WINDOW")
  hookMode            String              @default("AUTO_BEST_MIX")
  titlePrefix         String              @default("auto mix")
  hookPreviewSeconds  Int                 @default(8)
  status              String              @default("CREATED")
  recommendation      String?
  jobs                FactoryJob[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([sourceVideoId])
  @@index([accountId])
  @@index([status])
  @@index([createdAt])
}

model FactoryDonorChannel {
  id                String              @id @default(cuid())
  channelId          String
  channelTitle       String
  sourceUrl          String
  uploadsPlaylistId  String?
  subscriberCount    BigInt              @default(0)
  videoCount         BigInt              @default(0)
  viewCount          BigInt              @default(0)
  isActive           Boolean             @default(true)
  lastCheckedAt      DateTime?
  lastError          String?
  donorKind          FactoryDonorKind    @default(SUPER_UPLOAD)
  sourceVideos       FactorySourceVideo[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([channelId, donorKind])
  @@index([isActive])
  @@index([lastCheckedAt])
  @@index([createdAt])
  @@index([donorKind])
}

model FactoryMusicTrack {
  id                String    @id @default(cuid())
  title             String
  mood              String
  filePath          String
  storageKey        String?
  originalName      String?
  mimeType          String?
  sizeBytes         Int?
  isActive          Boolean   @default(true)
  copyrightStatus   String    @default("UNKNOWN")
  musicSource       String    @default("UNKNOWN")
  licenseType       String    @default("UNKNOWN")
  artist            String?
  sourceUrl         String?
  needsAttribution  Boolean   @default(false)
  attributionText   String?
  riskScore         Int       @default(50)
  blockedReason     String?
  confirmedSafeAt   DateTime?
  lastClaimAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([mood])
  @@index([isActive])
  @@index([createdAt])
  @@index([storageKey])
  @@index([copyrightStatus])
  @@index([musicSource])
}

model FactoryVkGroup {
  id            String                    @id @default(cuid())
  name          String
  url           String                    @unique
  category      String?
  isActive      Boolean                   @default(true)
  lastCheckedAt DateTime?
  lastError     String?
  candidates    FactoryVkVideoCandidate[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([isActive])
  @@index([lastCheckedAt])
  @@index([createdAt])
}

model FactoryVkVideoCandidate {
  id              String          @id @default(cuid())
  groupId         String
  group           FactoryVkGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sourceVideoId   String          @unique
  sourceUrl       String
  title           String
  description     String?
  thumbnailUrl    String?
  durationSeconds Int?
  score           Int             @default(50)
  isUsed          Boolean         @default(false)
  usedAt          DateTime?
  createdJobId    String?
  createdJob      FactoryJob?     @relation(fields: [createdJobId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([groupId])
  @@index([score])
  @@index([isUsed])
  @@index([createdAt])
  @@index([createdJobId])
}

model ViralReference {
  id            String                  @id @default(cuid())
  title         String
  sourceType    String
  sourceUrl     String?
  filePath      String?
  originalName  String?
  mimeType      String?
  durationSec   Int?
  thumbnailPath String?
  niche         String                  @default("ROBLOX")
  status        String                  @default("QUEUED")
  errorMessage  String?
  analyzedAt    DateTime?
  analysis      ViralReferenceAnalysis?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([niche])
  @@index([status])
  @@index([createdAt])
}

model ViralReferenceAnalysis {
  id                   String         @id @default(cuid())
  referenceId           String         @unique
  reference             ViralReference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  hookType              String
  hookLengthSec         Int
  storyType             String
  plotStructure         Json
  overlayTextStyle      Json
  emojiStyle            Json
  pacingStyle           String
  musicMood             String
  endingLogic           String
  titlePattern          String
  viralScore            Int            @default(0)
  extractedFormula      Json?
  rawAiAnalysis         Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([hookType])
  @@index([storyType])
  @@index([musicMood])
  @@index([viralScore])
}

model ViralFormula {
  id                 String   @id @default(cuid())
  niche              String   @default("ROBLOX")
  name               String
  hookType           String
  storyType          String
  musicMood          String
  titlePattern       String
  overlayTextPattern Json
  emojiPattern       Json
  plotBeats          Json
  pacing             Json
  endingLogic        String
  confidenceScore    Int      @default(0)
  sourceCount        Int      @default(1)
  notes              String?
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([niche])
  @@index([status])
  @@index([confidenceScore])
  @@index([sourceCount])
}

model ViralBrainSnapshot {
  id              String   @id @default(cuid())
  niche           String   @default("ROBLOX")
  referencesCount Int      @default(0)
  formulasCount   Int      @default(0)
  topHookTypes     Json
  topStoryTypes    Json
  topMusicMoods    Json
  titlePatterns    Json
  overlayPatterns  Json
  emojiPatterns    Json
  pacingRules      Json
  endingRules      Json
  promptContext    String
  rawSummary       Json?
  createdAt        DateTime @default(now())

  @@index([niche])
  @@index([createdAt])
}
