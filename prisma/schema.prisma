generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FactoryPlatform {
  YOUTUBE
  TIKTOK
}

enum FactoryJobStatus {
  QUEUED
  DOWNLOADING
  RENDERING
  PUBLISHING
  DONE
  FAILED
  CANCELED
}

enum FactoryPublishStatus {
  QUEUED
  UPLOADING
  PUBLISHED
  FAILED
  SKIPPED
  CANCELED
}

enum FactoryGame {
  ROBLOX
  FORTNITE
  MINECRAFT
  BRAWL_STARS
  DOTA2
  OTHER
}

model FactoryAsset {
  id           String   @id @default(cuid())
  title        String
  filePath     String
  storageKey   String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  templates    FactoryTemplate[]

  @@index([createdAt])
  @@index([storageKey])
}

model FactoryTemplate {
  id          String   @id @default(cuid())
  name        String
  isDefault   Boolean  @default(false)

  assetId     String?
  asset       FactoryAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  lanaX       Int      @default(78)
  lanaY       Int      @default(68)
  lanaWidth   Int      @default(300)
  lanaHeight  Int      @default(533)
  mirrorLana  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs         FactoryJob[]
  jobTargets   FactoryJobTarget[]

  @@index([isDefault])
  @@index([createdAt])
  @@index([assetId])
}

model FactoryAccount {
  id           String          @id @default(cuid())
  platform     FactoryPlatform
  name         String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  targets      FactoryJobTarget[]
  publishes    FactoryPublish[]

  @@unique([platform, name])
  @@index([platform])
}

model FactoryJob {
  id                 String            @id @default(cuid())

  sourceUrl          String?
  sourceFilePath     String?
  sourceStorageKey   String?
  sourceOriginalName String?
  sourceSizeBytes    Int?

  clipSeconds        Int               @default(45)
  titlePrefix        String            @default("Lana watches games")
  game               FactoryGame       @default(OTHER)

  templateId         String?
  template           FactoryTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  platforms          FactoryPlatform[]

  status             FactoryJobStatus  @default(QUEUED)
  error              String?
  totalClips         Int               @default(0)

  progress           Int               @default(0)
  progressLabel      String?
  cancelRequested    Boolean           @default(false)
  canceledAt         DateTime?

  targets            FactoryJobTarget[]
  clips              FactoryClip[]

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([cancelRequested])
  @@index([sourceStorageKey])
  @@index([game])
  @@index([templateId])
}

model FactoryJobTarget {
  id          String          @id @default(cuid())

  jobId       String
  job         FactoryJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  accountId   String
  account     FactoryAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  platform    FactoryPlatform

  templateId  String?
  template    FactoryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  titlePrefix String?

  publishes   FactoryPublish[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([jobId, accountId])
  @@index([jobId])
  @@index([accountId])
  @@index([platform])
  @@index([templateId])
}

model FactoryClip {
  id         String      @id @default(cuid())
  jobId      String
  job        FactoryJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  index      Int
  startSec   Int
  endSec     Int
  title      String
  filePath   String?
  storageKey String?

  publishes  FactoryPublish[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([jobId])
  @@index([createdAt])
  @@index([storageKey])
}

model FactoryPublish {
  id              String               @id @default(cuid())

  clipId          String
  clip            FactoryClip          @relation(fields: [clipId], references: [id], onDelete: Cascade)

  targetId        String?
  target          FactoryJobTarget?    @relation(fields: [targetId], references: [id], onDelete: SetNull)

  accountId       String?
  account         FactoryAccount?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  platform        FactoryPlatform
  status          FactoryPublishStatus @default(QUEUED)

  platformPostId  String?
  platformUrl     String?

  renderFilePath  String?
  renderStorageKey String?

  error           String?

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([clipId])
  @@index([targetId])
  @@index([accountId])
  @@index([platform])
  @@index([status])
}
